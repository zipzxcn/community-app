{
  "info": {
    "name": "community-backend file 联调集合",
    "_postman_id": "d1593c5d-c8f5-4f2a-aa9e-2095c7850711",
    "description": "文件上传流程：先获取上传凭证，上传后回调 complete，最后可删除文件。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Upload Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "try {",
              "  const json = pm.response.json();",
              "  if (json && json.code === 0 && json.data) {",
              "    pm.collectionVariables.set('bucketName', String(json.data.bucketName || ''));",
              "    pm.collectionVariables.set('objectKey', String(json.data.objectKey || ''));",
              "    pm.collectionVariables.set('uploadUrl', String(json.data.uploadUrl || ''));",
              "    const minioEndpoint = pm.collectionVariables.get('minioEndpoint') || 'http://127.0.0.1:9000';",
              "    if (json.data.bucketName && json.data.objectKey) {",
              "      pm.collectionVariables.set('fileAccessUrl', minioEndpoint + '/' + json.data.bucketName + '/' + json.data.objectKey);",
              "    }",
              "  }",
              "} catch (e) {}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bizType\": \"POST\",\n  \"fileName\": \"demo.png\",\n  \"contentType\": \"image/png\",\n  \"size\": {{uploadFileSize}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/files/upload-token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "files",
            "upload-token"
          ]
        }
      }
    },
    {
      "name": "Upload Binary To MinIO",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "image/png"
          }
        ],
        "body": {
          "mode": "file",
          "file": {
            "src": "{{uploadFilePath}}"
          }
        },
        "url": "{{uploadUrl}}"
      }
    },
    {
      "name": "Complete Upload",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "try {",
              "  const json = pm.response.json();",
              "  if (json && json.code === 0 && json.data && json.data.id) {",
              "    pm.collectionVariables.set('fileId', String(json.data.id));",
              "  }",
              "} catch (e) {}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bizType\": \"POST\",\n  \"bizId\": null,\n  \"bucketName\": \"{{bucketName}}\",\n  \"objectKey\": \"{{objectKey}}\",\n  \"accessUrl\": \"{{fileAccessUrl}}\",\n  \"originalName\": \"demo.png\",\n  \"mimeType\": \"image/png\",\n  \"sizeBytes\": {{uploadFileSize}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/files/complete",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "files",
            "complete"
          ]
        }
      }
    },
    {
      "name": "Delete File",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/files/{{fileId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "files",
            "{{fileId}}"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "bucketName",
      "value": ""
    },
    {
      "key": "objectKey",
      "value": ""
    },
    {
      "key": "uploadUrl",
      "value": ""
    },
    {
      "key": "uploadFilePath",
      "value": "target/e2e-upload.png"
    },
    {
      "key": "uploadFileSize",
      "value": "67"
    },
    {
      "key": "minioEndpoint",
      "value": "http://127.0.0.1:9000"
    },
    {
      "key": "fileAccessUrl",
      "value": ""
    },
    {
      "key": "fileId",
      "value": "1"
    }
  ]
}
