{
  "info": {
    "name": "community-backend chat 联调集合",
    "_postman_id": "8f2f612e-4f18-45b0-8b28-c5fdc2926248",
    "description": "聊天模块接口联调集合。先登录拿 token，再打开会话并发送消息。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Threads",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/chat/threads?page=1&size=20",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "chat",
            "threads"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "Open Thread With User",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "try {",
              "  const json = pm.response.json();",
              "  if (json && json.code === 0 && json.data && json.data.threadId) {",
              "    pm.collectionVariables.set('threadId', String(json.data.threadId));",
              "  }",
              "} catch (e) {}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/chat/threads/with/{{targetUserId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "chat",
            "threads",
            "with",
            "{{targetUserId}}"
          ]
        }
      }
    },
    {
      "name": "List Messages",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/chat/threads/{{threadId}}/messages?size=20",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "chat",
            "threads",
            "{{threadId}}",
            "messages"
          ],
          "query": [
            {
              "key": "size",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "Send Message",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('clientMsgId', `msg_${Date.now()}`);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clientMsgId\": \"{{clientMsgId}}\",\n  \"messageType\": \"TEXT\",\n  \"content\": \"这是一条联调私信\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/chat/threads/{{threadId}}/messages",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "chat",
            "threads",
            "{{threadId}}",
            "messages"
          ]
        }
      }
    },
    {
      "name": "Mark Read",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"lastReadMessageId\": {{lastReadMessageId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/chat/threads/{{threadId}}/read",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "chat",
            "threads",
            "{{threadId}}",
            "read"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "targetUserId",
      "value": "2"
    },
    {
      "key": "threadId",
      "value": "1"
    },
    {
      "key": "clientMsgId",
      "value": "msg_001"
    },
    {
      "key": "lastReadMessageId",
      "value": "1"
    }
  ]
}
