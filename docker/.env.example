# Community App Docker 部署环境变量示例
# 使用方式：
#   cd docker
#   copy .env.example .env   # Windows PowerShell 可用：Copy-Item .env.example .env
#   docker compose --env-file .env up -d --build

# 时区
TZ=Asia/Shanghai

# 对外访问端口
FRONTEND_PORT=8088
BACKEND_PORT=8080
MYSQL_PORT=3306
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MySQL
MYSQL_DATABASE=community_app
MYSQL_ROOT_PASSWORD=community_root_password

# JWT
# 生产环境请替换为更长、更随机的密钥。
APP_JWT_SECRET=change-this-secret-change-this-secret
APP_JWT_ACCESS_TOKEN_EXPIRE_SECONDS=7200
APP_JWT_REFRESH_TOKEN_EXPIRE_SECONDS=1209600

# MinIO / 对象存储
MINIO_ROOT_USER=community_minio
MINIO_ROOT_PASSWORD=community_minio_password
MINIO_BUCKET=community-prod

# 预签名上传地址使用的公开端点。
# Docker Desktop 本机部署默认可用 host.docker.internal:9000；
# 云服务器部署请改为浏览器可访问的域名或服务器 IP，例如 http://your-server-ip:9000。
MINIO_PUBLIC_ENDPOINT=http://host.docker.internal:9000
APP_STORAGE_UPLOAD_EXPIRE_SECONDS=900

# 浏览历史清理任务
APP_HISTORY_CLEANUP_ENABLED=true
APP_HISTORY_CLEANUP_RETENTION_DAYS=180
APP_HISTORY_CLEANUP_CRON=0 15 3 * * *
